# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/itc_rec

# Security
# Run `openssl rand -hex 32` to generate a secret key
SECRET_KEY=supersecretkeythatshouldbechangedinproduction
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Uploads
MAX_UPLOAD_MB=50

# Email (SMTP)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=smtppassword
SMTP_FROM_EMAIL=noreply@itc-rec.example.com
